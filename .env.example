OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

PUSHPLUS_TOKEN=
WEBSITE_URL=
X_PROFILE_URL=

DATABASE_URL=file:./data/bot.db
DATABASE_AUTH_TOKEN=

BOT_TIMEZONE=America/New_York
POST_WINDOW_START_HOUR=8
POST_WINDOW_END_HOUR=21
DAILY_POST_MIN=2
DAILY_POST_MAX=4
MIN_GAP_MINUTES=120
MAX_GAP_MINUTES=360
RANDOM_JITTER_MINUTES=5

MAX_RETRY_ATTEMPTS=3
CIRCUIT_BREAKER_FAILURE_THRESHOLD=4
LOOKBACK_POST_LIMIT=150

LANGUAGE_STRATEGY=en
ENABLE_SEMANTIC_DEDUP=true
KEYWORD_SIMILARITY_THRESHOLD=0.72
SEMANTIC_SIMILARITY_THRESHOLD=0.85
CONTENT_HARD_BLOCK_TERMS=guaranteed income,passive income overnight,DM me for access,100% win

TOPIC_WEIGHTS=ai_monetization_case_studies:30,ai_tools_and_workflows:25,ai_startup_ideas:20,ai_industry_insights:15,ai_prompts_and_productivity:10
TONE_POOL=operator,analyst,founder,builder,educator
ANGLE_POOL=framework,case_study,contrarian,step_by_step,breakdown,prediction,mistake,prompt,comparison,playbook

DRY_RUN=true
